{
  "manifest_version": 3,
  "name": "\u4e39\u79d8 Browser Bridge",
  "version": "0.8.5",
  "description": "AI agent \u6d4f\u89c8\u5668\u81ea\u52a8\u5316\u6865\u63a5 \u2014 Command API + CDP",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "notifications",
    "scripting",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/service_worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}